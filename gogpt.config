model "gpt" {
  model_name = "gpt-5.5"
  base_url = "https://api.openai.com/v1"
  api_key = "%OPENAI_API_KEY%"
  params = { "reasoning": { "effort": "none" } }
}

model "fast" {
  model_name = "gpt-5.4-mini"
  base_url = "https://api.openai.com/v1"
  api_key = "%OPENAI_API_KEY%"
  params = { "reasoning": { "effort": "none" } }
}

model "cheap" {
  model_name = "gpt-5.4-nano"
  base_url = "https://api.openai.com/v1"
  api_key = "%OPENAI_API_KEY%"
  params = { "reasoning": { "effort": "none" } }
}

model "yagpt" {
  model_name = "gpt://%folder_id%/yandexgpt-5.1"
  base_url = "https://ai.api.cloud.yandex.net/v1"
  api_key = "%api_key%"
  project = "%folder_id%"
}

model "yagpt-pro" {
  model_name = "gpt://%folder_id%/yandexgpt-5-pro"
  base_url = "https://ai.api.cloud.yandex.net/v1"
  api_key = "%api_key%"
  project = "%folder_id%"
}

model "qwen" {
  model_name = "gpt://%folder_id%/qwen3.5-35b-a3b-fp8"
  base_url = "https://ai.api.cloud.yandex.net/v1"
  api_key = "%api_key%"
  project = "%folder_id%"
}

model "qwen3" {
  model_name = "gpt://%folder_id%/qwen3-235b-a22b-fp8"
  base_url = "https://ai.api.cloud.yandex.net/v1"
  api_key = "%api_key%"
  project = "%folder_id%"
}

model "deepseek" {
  model_name = "gpt://%folder_id%/deepseek-v32"
  base_url = "https://ai.api.cloud.yandex.net/v1"
  api_key = "%api_key%"
  project = "%folder_id%"
  default = true
}

template "translate" = """
Please, translate the text in triple backquotes below into the following language: {param_1}. Here is the text:
```{}```
"""

template "summarize" = """
Please, summarize the text in triple backquotes below:
```{}```
"""

template "expand" = """
Please, rewrite the text in triple backquotes below in the longest possible form:
```{}```
"""

template "explain-code" = """
Please explain what the following code does, including important edge cases:
```{}```
"""

template "fix-text" = """
Please rewrite the text below so it is clear, concise, and natural. Preserve the original meaning:
```{}```
"""

template "bullets" = """
Please convert the text below into concise bullet points:
```{}```
"""

system "rude" = """
You are extremely rude chatbot that does not want to talk to anyone.
"""

system "expert" = """
You are a careful technical expert. Give precise, practical answers and call out assumptions.
"""
